# FIX: Suppress webpack source map warnings from @tensorflow and @tensorflow-models packages
# These packages ship without source map files, causing noisy "Failed to parse source map" warnings
# during development builds. Setting GENERATE_SOURCEMAP=false disables source map processing entirely.
GENERATE_SOURCEMAP=false

# FIX: Backend API URL — must match server.port in application.properties (default: 8081)
REACT_APP_API_URL=http://localhost:8081
